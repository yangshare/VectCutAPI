{
  "draft_profile": "capcut_legacy",  // capcut_legacy, jianying_legacy, or jianying_pro_10 for Jianying Pro 10.x
  "is_capcut_env": true,  // Backward-compatible fallback. Ignored when draft_profile is set.
  "draft_domain": "https://www.capcutapi.top",  // Base domain for draft operations
  "api_base_url": "https://api.vectcut.com/api",  // Base URL for VectCut API calls
  "port": 9001,  // Port number for the local server
  "preview_router": "/draft/downloader",  // Router path for preview functionality
  "is_upload_draft": false,  // Whether to upload drafts to remote storage
  "draft_folder": "",  // Local draft output folder (absolute path). If empty, saves to server working directory. e.g. "C:\\Users\\<user>\\AppData\\Local\\JianyingPro\\User Data\\Projects\\com.lveditor.draft"
  "template_folder": "/app/data/templates",  // Template package storage folder
  "template_config_folder": "/app/data/template_configs",  // Template config storage folder
  "generated_draft_folder": "/app/data/generated",  // Generated draft output folder
  "temp_folder": "/app/data/temp",  // Temporary file folder
  "max_template_zip_mb": "${MAX_TEMPLATE_ZIP_MB}",  // Maximum template ZIP upload size in MB
  "auth": {
    "api_token": "${API_AUTH_TOKEN}"  // API authentication token from environment
  },
  "oss_config": {  // General OSS (Object Storage Service) configuration
    "enabled": false,  // Whether to enable general OSS storage
    "bucket_name": "${OSS_BUCKET}",  // OSS bucket name for general storage
    "access_key_id": "${OSS_ACCESS_KEY}",  // Access key ID for OSS authentication
    "access_key_secret": "${OSS_ACCESS_SECRET}",  // Access key secret for OSS authentication
    "endpoint": "${OSS_ENDPOINT}"  // OSS service endpoint URL
  },
  "mp4_oss_config": {  // MP4-specific OSS configuration
    "bucket_name": "your-mp4-bucket-name",  // OSS bucket name for MP4 files
    "access_key_id": "your-access-key-id",  // Access key ID for MP4 OSS authentication
    "access_key_secret": "your-access-key-secret",  // Access key secret for MP4 OSS authentication
    "region": "your-region",  // Region for MP4 storage
    "endpoint": "http://your-custom-domain"  // Custom domain endpoint for MP4 access
  }
}
